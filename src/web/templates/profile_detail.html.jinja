{% extends "base.html.jinja" %} {% block content %}
<div class="p-6 space-y-6" x-data="profileDetailData('{{ profile_name }}')">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div class="flex items-center space-x-4">
            <a href="/dashboard/" class="text-slate-400 hover:text-slate-200 transition-colors duration-200">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </a>
            <div>
                <h1 class="text-3xl font-bold text-slate-100">{{ profile_name }}</h1>
                <p class="mt-1 text-slate-400">
                    Profile synchronization details and history
                </p>
            </div>
        </div>

        <!-- Profile actions -->
        <div class="flex space-x-3">
            <button @click="triggerSync(false)" :disabled="syncing"
                class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200">
                <svg x-show="!syncing" class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                <svg x-show="syncing" x-cloak class="mr-2 h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                <span x-text="syncing ? 'Syncing...' : 'Sync Now'"></span>
            </button>

            <button @click="triggerSync(true)" :disabled="syncing"
                class="inline-flex items-center px-4 py-2 border border-slate-600 text-sm font-medium rounded-md text-slate-300 bg-slate-800 hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200">
                <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
                Poll Sync
            </button>
        </div>
    </div>

    <!-- Profile Configuration -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Configuration Card -->
        <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
            <h2 class="text-lg font-medium text-slate-100 mb-4">Configuration</h2>

            <div class="space-y-4">
                <div class="flex justify-between items-center gap-4">
                    <span class="text-slate-400 flex-shrink-0">Plex User:</span>
                    <span class="text-slate-100 font-medium truncate min-w-0 text-right"
                        title="{{ profile_config.plex_user }}">{{ profile_config.plex_user }}</span>
                </div>

                <div class="flex justify-between items-center gap-4">
                    <span class="text-slate-400 flex-shrink-0">AniList User:</span>
                    <span class="text-slate-100 font-medium truncate min-w-0 text-right"
                        title="Connected">{{ anilist_user }}</span>
                </div>

                <div class="flex justify-between items-center gap-4">
                    <span class="text-slate-400 flex-shrink-0">Sync Interval:</span>
                    <span class="text-slate-100 truncate min-w-0 text-right"
                        title="{% if profile_config.sync_interval == -1 %}Run Once{% else %}{{ profile_config.sync_interval }}s{% endif %}">
                        {% if profile_config.sync_interval == -1 %} Run Once {% else %}
                        {{ profile_config.sync_interval }}s {% endif %}
                    </span>
                </div>

                <div class="flex justify-between items-center gap-4">
                    <span class="text-slate-400 flex-shrink-0">Sync Mode:</span>
                    <span class="text-slate-100 truncate min-w-0 text-right"
                        title="{{ 'Polling' if profile_config.polling_scan else 'Periodic' }}">
                        {{ 'Polling' if profile_config.polling_scan else 'Periodic' }}
                    </span>
                </div>

                <div class="flex justify-between items-center gap-4">
                    <span class="text-slate-400 flex-shrink-0">Library Sections:</span>
                    <span class="text-slate-100 truncate min-w-0 text-right"
                        title="{% if profile_config.plex_sections %}{{ profile_config.plex_sections|join(', ') }}{% else %}All sections{% endif %}">
                        {% if profile_config.plex_sections %}
                        {{ profile_config.plex_sections|join(', ') }}
                        {% else %} All sections {% endif %}
                    </span>
                </div>

                <div class="flex justify-between items-center gap-4">
                    <span class="text-slate-400 flex-shrink-0">Item Genres:</span>
                    <span class="text-slate-100 truncate min-w-0 text-right"
                        title="{% if profile_config.plex_genres %}{{ profile_config.plex_genres|join(', ') }}{% else %}All genres{% endif %}">
                        {% if profile_config.plex_genres %}
                        {{ profile_config.plex_genres|join(', ') }}
                        {% else %} All genres {% endif %}
                    </span>
                </div>
            </div>

            <!-- Settings badges -->
            <div class="mt-6 flex flex-wrap gap-2">
                {% if profile_config.full_scan %}
                <span
                    class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-900 text-blue-200">
                    Full Scan
                </span>
                {% endif %} {% if profile_config.destructive_sync %}
                <span
                    class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-900 text-red-200">
                    Destructive Sync
                </span>
                {% endif %} {% if profile_config.dry_run %}
                <span
                    class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-yellow-900 text-yellow-200">
                    Dry Run
                </span>
                {% endif %} {% if profile_config.batch_requests %}
                <span
                    class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-purple-900 text-purple-200">
                    Batch Requests
                </span>
                {% endif %}
            </div>
        </div>

        <!-- Statistics Card -->
        <div class="bg-slate-800 border border-slate-700 rounded-lg p-6" hx-get="/profiles/{{ profile_name }}/stats"
            hx-trigger="load, every 30s" hx-target="#profile-stats" hx-swap="innerHTML">
            <h2 class="text-lg font-medium text-slate-100 mb-4">Statistics</h2>

            <div id="profile-stats" class="space-y-4">
                <!-- Loading state -->
                <div class="animate-pulse">
                    <div class="h-4 bg-slate-700 rounded w-3/4 mb-2"></div>
                    <div class="h-4 bg-slate-700 rounded w-1/2 mb-2"></div>
                    <div class="h-4 bg-slate-700 rounded w-2/3"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sync History Timeline -->
    <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-lg font-medium text-slate-100">Sync History</h2>
            <button @click="refreshTimeline()"
                class="text-slate-400 hover:text-slate-200 transition-colors duration-200">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </button>
        </div>

        <div id="timeline-container" hx-get="/profiles/{{ profile_name }}/timeline"
            hx-trigger="load, every 15s, refresh-timeline from:body" hx-target="#timeline-container"
            hx-swap="innerHTML">
            <!-- Loading state -->
            <div class="space-y-4">
                {% for i in range(5) %}
                <div class="flex items-start space-x-4 animate-pulse">
                    <div class="flex-shrink-0 w-8 h-8 bg-slate-700 rounded-full"></div>
                    <div class="flex-1 space-y-2">
                        <div class="h-4 bg-slate-700 rounded w-3/4"></div>
                        <div class="h-3 bg-slate-700 rounded w-1/2"></div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <!-- Notification area -->
    <div x-show="notification.show" x-cloak x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0 transform translate-y-2"
        x-transition:enter-end="opacity-100 transform translate-y-0"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100 transform translate-y-0"
        x-transition:leave-end="opacity-0 transform translate-y-2" class="fixed bottom-4 right-4 z-50">
        <div class="bg-slate-800 border border-slate-700 rounded-lg shadow-lg p-4 max-w-sm" :class="{
                'border-green-600': notification.type === 'success',
                'border-red-600': notification.type === 'error',
                'border-blue-600': notification.type === 'info'
             }">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg x-show="notification.type === 'success'" class="h-5 w-5 text-green-400" fill="currentColor"
                        viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                            d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                            clip-rule="evenodd" />
                    </svg>
                    <svg x-show="notification.type === 'error'" class="h-5 w-5 text-red-400" fill="currentColor"
                        viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                            d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                            clip-rule="evenodd" />
                    </svg>
                    <svg x-show="notification.type === 'info'" class="h-5 w-5 text-blue-400" fill="currentColor"
                        viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                            d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                            clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-medium text-slate-100" x-text="notification.message"></p>
                </div>
                <div class="ml-auto pl-3">
                    <button @click="notification.show = false" class="inline-flex text-slate-400 hover:text-slate-200">
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                                clip-rule="evenodd" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function profileDetailData(profileName) {
        return {
            profileName: profileName,
            syncing: false,
            notification: {
                show: false,
                message: '',
                type: 'info'
            },

            async triggerSync(poll) {
                this.syncing = true

                try {
                    const response = await fetch(
                        `/api/sync/${this.profileName}/trigger`,
                        {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({ poll })
                        }
                    )

                    const result = await response.json()

                    if (response.ok) {
                        this.showNotification(result.message, 'success')
                        // Refresh stats and timeline after sync
                        setTimeout(() => {
                            htmx.trigger(document.body, 'refresh-timeline')
                        }, 2000)
                    } else {
                        this.showNotification(result.detail || 'Sync failed', 'error')
                    }
                } catch (error) {
                    this.showNotification('Failed to trigger sync', 'error')
                } finally {
                    this.syncing = false
                }
            },

            refreshTimeline() {
                htmx.trigger(document.body, 'refresh-timeline')
            },

            showNotification(message, type = 'info') {
                this.notification = { show: true, message, type }
                setTimeout(() => {
                    this.notification.show = false
                }, 5000)
            }
        }
    }
</script>
{% endblock %}