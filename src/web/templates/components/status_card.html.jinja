{% for profile_name, profile_data in profiles.items() %}
<div class="bg-slate-800 border border-slate-700 rounded-lg p-6 hover:border-slate-600 transition-colors duration-200"
    x-data="profileCard('{{ profile_name }}')">
    <!-- Profile Header -->
    <div class="flex items-start justify-between mb-4">
        <div class="flex-1">
            <h3 class="text-lg font-medium text-slate-100">{{ profile_name }}</h3>
            <p class="text-sm text-slate-400 mt-1">
                {{ profile_data.config.plex_user }} →
                {{ profile_data.config.anilist_user }}
            </p>
        </div>

        <!-- Status indicator -->
        <div class="flex items-center space-x-2">
            {% if profile_data.status.running %}
            <div class="h-2 w-2 bg-green-500 rounded-full pulse-blue"></div>
            <span class="text-xs text-green-400">Running</span>
            {% else %}
            <div class="h-2 w-2 bg-slate-500 rounded-full"></div>
            <span class="text-xs text-slate-400">Stopped</span>
            {% endif %}
        </div>
    </div>

    <!-- Profile Info -->
    <div class="space-y-3 mb-4">
        <div class="flex justify-between text-sm">
            <span class="text-slate-400">Sync Interval:</span>
            <span class="text-slate-300">
                {% if profile_data.config.sync_interval == -1 %} Run Once {% else %}
                {{ profile_data.config.sync_interval }}s {% endif %}
            </span>
        </div>

        <div class="flex justify-between text-sm">
            <span class="text-slate-400">Mode:</span>
            <span class="text-slate-300">
                {{ 'Polling' if profile_data.config.polling_scan else 'Periodic' }}
            </span>
        </div>

        <div class="flex justify-between text-sm">
            <span class="text-slate-400">Last Synced:</span>
            <span class="text-slate-300">
                {% if profile_data.status.last_synced %}
                <span x-data="{ time: '{{ profile_data.status.last_synced }}' }"
                    x-text="formatRelativeTime(time)"></span>
                {% else %} Never {% endif %}
            </span>
        </div>
    </div>

    <!-- Settings badges -->
    <div class="flex flex-wrap gap-2 mb-4">
        {% if profile_data.config.full_scan %}
        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-blue-900 text-blue-200">
            Full Scan
        </span>
        {% endif %} {% if profile_data.config.destructive_sync %}
        <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-red-900 text-red-200">
            Destructive
        </span>
        {% endif %}
    </div>

    <!-- Actions -->
    <div class="flex space-x-2">
        <button @click="triggerProfileSync('{{ profile_name }}', false)" :disabled="syncing"
            class="flex-1 inline-flex items-center justify-center px-3 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 disabled:opacity-50 disabled:cursor-not-allowed transition-colors duration-200">
            <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            Sync
        </button>

        <a href="/profiles/{{ profile_name }}"
            class="inline-flex items-center justify-center px-3 py-2 border border-slate-600 text-sm font-medium rounded-md text-slate-300 bg-slate-700 hover:bg-slate-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 transition-colors duration-200">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </a>
    </div>
</div>
{% endfor %}