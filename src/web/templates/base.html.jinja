<!DOCTYPE html>
<html lang="en" class="dark">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% block title %}{{ title }} - {{ app_name }}{% endblock %}</title>
    <link rel="icon" href="{{ url_for('static', path='favicon.ico') }}" type="image/x-icon" />

    <!-- HTMX -->
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2/dist/htmx.min.js"></script>

    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3/dist/cdn.min.js"></script>

    <!-- Tailwind CSS -->
    <style type="text/tailwindcss">
        @import "tailwindcss";
        
        @theme {
            --color-primary-50: #eff6ff;
            --color-primary-100: #dbeafe;
            --color-primary-200: #bfdbfe;
            --color-primary-300: #93c5fd;
            --color-primary-400: #60a5fa;
            --color-primary-500: #3b82f6;
            --color-primary-600: #2563eb;
            --color-primary-700: #1d4ed8;
            --color-primary-800: #1e40af;
            --color-primary-900: #1e3a8a;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4" crossorigin></script>

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/static/css/main.css" />
</head>

<body class="bg-slate-900 text-slate-100 min-h-screen" x-data="{ sidebarOpen: false }">
    <!-- Navigation -->
    <nav class="bg-slate-800 border-b border-slate-700 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Left: Logo and mobile menu -->
                <div class="flex items-center">
                    <!-- Mobile menu button -->
                    <button @click="sidebarOpen = !sidebarOpen"
                        class="md:hidden p-2 rounded-md text-slate-400 hover:text-slate-100 hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-primary-500">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 6h16M4 12h16M4 18h16" />
                        </svg>
                    </button>
                    <!-- Logo and app name -->
                    <div class="flex items-center ml-4 md:ml-0">
                        <img src="{{ url_for('static', path='img/logo.png') }}" alt="{{ app_name }}" class="h-8 w-8" />
                        <h1 class="ml-3 text-xl font-bold text-slate-100">
                            {{ app_name }}
                        </h1>
                    </div>
                </div>
                <!-- Right: Status and version -->
                <div class="flex items-center space-x-4">
                    <!-- Status indicator -->
                    <div class="flex items-center space-x-2" hx-get="/api/health" hx-trigger="load, every 30s"
                        hx-target="#health-status">
                        <div id="health-status" class="flex items-center space-x-2">
                            <div id="connection-status" class="h-2 w-2 bg-slate-500 rounded-full" title="Connecting...">
                            </div>
                            <span class="text-sm text-slate-400">Connecting...</span>
                        </div>
                    </div>
                    <!-- Version -->
                    <span class="text-sm text-slate-500">v{{ app_version }}</span>
                </div>
            </div>
        </div>
    </nav>

    <!-- Mobile sidebar overlay -->
    <div x-show="sidebarOpen" x-cloak @click="sidebarOpen = false"
        class="fixed inset-0 z-40 bg-slate-900 bg-opacity-75 md:hidden"
        x-transition:enter="transition-opacity ease-linear duration-300" x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100" x-transition:leave="transition-opacity ease-linear duration-300"
        x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"></div>

    <div class="flex">
        <!-- Sidebar -->
        <aside
            class="fixed inset-y-0 left-0 z-50 w-64 bg-slate-800 transform md:relative md:translate-x-0 transition duration-200 ease-in-out md:flex md:flex-col"
            :class="{ '-translate-x-full': !sidebarOpen, 'translate-x-0': sidebarOpen }" x-cloak>
            <div class="flex-1 flex flex-col pt-5 pb-4 overflow-y-auto">
                <nav class="mt-5 flex-1 px-2 space-y-1">
                    <a href="/dashboard/"
                        class="group flex items-center px-2 py-2 text-sm font-medium rounded-md transition-colors duration-150 {% if request.url.path.startswith('/dashboard') %}bg-primary-600 text-white{% else %}text-slate-300 hover:bg-slate-700 hover:text-white{% endif %}">
                        <svg class="mr-3 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M8 5a2 2 0 012-2h4a2 2 0 012 2v2H8V5z" />
                        </svg>
                        Dashboard
                    </a>

                    <a href="/logs/"
                        class="group flex items-center px-2 py-2 text-sm font-medium rounded-md transition-colors duration-150 {% if request.url.path.startswith('/logs') %}bg-primary-600 text-white{% else %}text-slate-300 hover:bg-slate-700 hover:text-white{% endif %}">
                        <svg class="mr-3 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        Logs
                    </a>
                </nav>
            </div>
        </aside>

        <!-- Main content -->
        <main class="flex-1 min-h-screen">{% block content %}{% endblock %}</main>
    </div>

    <script src="/static/js/utils.js"></script>

    <script>
        document.body.addEventListener('htmx:afterRequest', function (event) {
            if (
                event.detail.target.id === 'health-status' &&
                event.detail.xhr.status === 200
            ) {
                const response = JSON.parse(event.detail.xhr.responseText)
                const statusEl = document.getElementById('health-status')
                const isHealthy = response.status === 'healthy'

                statusEl.innerHTML = `
                    <div id="connection-status" class="h-2 w-2 rounded-full ${isHealthy ? 'bg-green-500 pulse-blue' : 'bg-red-500'
                    }" title="${isHealthy ? 'Online' : 'Offline'}"></div>
                    <span class="text-sm text-slate-400">${isHealthy ? 'Online' : 'Offline'
                    }</span>
                `
            }
        })
    </script>
</body>

</html>